{% extends 'base.html.twig' %}

{% block title %}Erreur - {{ parent() }}{% endblock %}

{% block body %}
   <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6 text-center">
        
        <img src="{{ asset('assets/images/icon/dead.svg') }}" class="bi bi-exclamation-octagon-fill text-danger" style="height:auto;width:90%;max-width 500px;" >

        
        <h2>Une erreur est survenue!</h2>

        <p class="lead text-muted mb-5 text-white fs-6">
            Nous rencontrons actuellement un problème technique sur nos serveurs. Nos équipes techniques ont été alertées et travaillent à la résolution du problème dans les plus brefs délais. Veuillez nous excuser pour la gêne occasionnée.
        </p>
        <a href="{{ path('app_login') }}" class="btn btn-outline-light px-5">
            Retour à l'accueil
        </a>
        
    </div>
</div>
{% endblock %}