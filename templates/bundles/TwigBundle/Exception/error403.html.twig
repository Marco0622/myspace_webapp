{% extends 'base.html.twig' %}

{% block title %}Accéss Refuser{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6 text-center">
        
        <img src="{{ asset('assets/images/icon/403.svg') }}" class="bi bi-exclamation-octagon-fill text-danger" width="100%" >

        
        <h2>Accès restreint !</h2>

        <p class="lead text-muted mb-5 text-white fs-6">
            Vous n'avez pas les autorisations nécessaires pour accéder à cette ressource. Si vous pensez qu'il s'agit d'une erreur, nous vous invitons à contacter l'administrateur du site ou à vérifier vos identifiants de connexion.
        </p>

        {% if app.user.id is defined %}
        <a href="{{ path('app_user_home') }}" class="btn btn-outline-light btn-lg px-5">
            Retour à l'accueil
        </a>
        {% else %}
            <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-lg px-5">
                Retour à l'accueil
            </a>
        {% endif %}
    </div>
</div>
   
{% endblock %}