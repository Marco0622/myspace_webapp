{% extends 'base.html.twig' %}

{% block title %}403 - {{ parent() }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6 text-center">
        
        <img src="{{ asset('assets/images/icon/403.svg') }}" class="bi bi-exclamation-octagon-fill text-danger" style="height:auto;width:90%;max-width 500px;" >

        
        <h2>Accès restreint !</h2>

        <p class="lead text-muted mb-5 text-white fs-6">
            Vous n'avez pas les autorisations nécessaires pour accéder à cette ressource. Si vous pensez qu'il s'agit d'une erreur, nous vous invitons à contacter l'administrateur du site ou à vérifier vos identifiants de connexion.
        </p>

        <a href="{{ path('app_login') }}" class="btn btn-outline-light px-5">
            Retour à l'accueil
        </a>
        
    </div>
</div>
   
{% endblock %}