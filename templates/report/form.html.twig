{% extends 'base.html.twig' %}

{% block title %}Signalement - {{ parent() }}{% endblock %}

{% block body %}
<section class="py-5">
    <div class="row justify-content-center">
        <div class="card p-3 p-md-5">
            <h1 class="display-5 mb-4 text-white text-uppercase fw-bold">Signalement</h1>
            <p class="text-white-50 mb-5">Un problème ou une demande ? Envoyez-nous un message via le formulaire ci-dessous.</p>
            {{ form(reportForm) }}
        </div>
    </div>
</section>
{% endblock %}
