{% extends 'base.html.twig' %}

{% block title %}Signalement - {{ parent() }}{% endblock %}

{% block javascripts %}
	{{ importmap(['app', 'inputAnimation']) }}
{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12">

            <div class="mb-5">
                <h1 class="display-5 text-uppercase fw-bold">Signalement</h1>
                <p class="text-white-50">Un problème ou une demande ? Envoyez-nous un message via le formulaire ci-dessous.</p>
                <hr class="border-secondary opacity-25">
            </div>

            {{ form_start(reportForm) }}
                
                <div class="mb-3 animate-in">
                    {{ form_row(reportForm.subject) }}
                </div>

                <div class="mb-3 animate-in">
                    {{ form_row(reportForm.content) }}
                </div>

                <div class="mt-4 animate-in">
                    {{ form_row(reportForm.submit) }}
                </div>

            {{ form_end(reportForm) }}

        </div>
    </div>
</div>
{% endblock %}