{% extends 'base.html.twig' %}

{% block title %}Hello ReportController!{% endblock %}

{% block body %}
<section class="py-5">
    <div class="row justify-content-center">
        <div class="card p-3">
            <a href="{{ app.request.headers.get('referer') ?? path('app_user_home') }}" class="text-white text-decoration-none pb-2">
                {{ ux_icon('lucide:arrow-left', {width: 64, height: 48}) }}
            </a>
            <h1 class="display-5 mb-4 text-white text-uppercase fw-bold">Signalement</h1>
            <p class="text-white-50 mb-5">Un problème ou une demande ? Envoyez-nous un message via le formulaire ci-dessous.</p>
            {{ form(reportForm) }}
        </div>
    </div>
</section>
{% endblock %}
