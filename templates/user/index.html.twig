{% extends 'base.html.twig' %}

{% block title %}Hello UserController!{% endblock %}

{% block body %}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-0 fw-medium">Bonjour, {{ app.user.pseudo ?? (app.user.name ~ " " ~ app.user.firstname) }} </h1>
        <p class="text-white mb-0 ">Bienvenue sur votre espace ! {{ ux_icon('boxicons:smile-filled') }}</p>
    </div>
</div>

<div class="d-flex align-items-center justify-content-between w-100 py-2 border-bottom border-white pb-2">
    <h3 class="fw-medium mb-0">
        Invitations reçues
    </h3>
    <a href="{{ path('app_user_home') }}" class="btn btn-light d-flex align-items-center gap-2">
        {{ ux_icon('zondicons:reload') }} Actualiser
    </a>
</div>

<div class="row g-3 my-2">
    {% for invitation in arrInvitation %}
        <div class="col-12 mb-2">
            <div class="card border">
                <div class="card-body py-2">
                    <div class="row align-items-center g-3">
                        <div class="col-12 col-sm-auto text-center">
                            <span class="badge bg-success">Invitation</span>
                        </div>
                        <div class="col-12 col-md">
                            <h6 class="mb-0 fw-medium text-white text-center text-md-start text-uppercase">{{ invitation.session.name }}</h6>
                            <small class="text-white-50 d-block text-center text-md-start">De : {{ invitation.senderId.pseudo ?? invitation.senderId.name ~ " " ~ invitation.senderId.firstname}} • il y a {{ invitation.sendAt|date_diff }}</small>
                        </div>
                        <div class="col-12 col-md-auto d-flex flex-column flex-md-row gap-2 ms-md-auto">
                            <a href="{{ path('app_invitation_accept', { id: invitation.id })}}" class="btn btn-sm btn-success d-flex align-items-center justify-content-center gap-1 w-100 w-md-auto">
                                {{ ux_icon('rivet-icons:check') }} Accepter
                            </a>
                            <a href="{{ path('app_invitation_decline', { id: invitation.id })}}" class="btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center gap-1 w-100 w-md-auto">
                                {{ ux_icon('lucide:x') }} Refuser
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <h5 class="text-center text-white-50"> Aucune Invitation ! </h5>
    {% endfor %}
</div>

<div class="d-flex align-items-center justify-content-between w-100 py-2 border-bottom border-white pb-2">
    <h3 class="fw-medium mb-0">
        Vos sessions
    </h3>
    <a href="" class="btn btn-light d-flex align-items-center gap-2">
        {{ ux_icon('fa7-solid:plus') }} Créer une session
    </a>
</div>

<div class="row g-3 py-3">
    {% for session in arrSession %}
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card border h-100">
                <div class="card-body d-flex flex-column gap-2">
                    <div class="d-flex align-items-start justify-content-between">
                        <span class="badge bg-primary">Session</span>
                        <small class="text-white">{{ session.createdAt.date|format_datetime( 'long', 'none', locale='fr') }}</small>
                    </div>
                    <h6 class="mb-0 fw-medium text-white text-uppercase">{{ session.name }}</h6>
                    <p class="text-white"> <strong>Propriétaire :</strong> </p>
                    {% for access in session.sessionAccesses %}
                        {% if access.role == 'ROLE_OWNER' %}
                            {% if app.user.id != access.member.id %}
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle overflow-hidden border border-2 border-white flex-shrink-0" style="width: 40px; height: 40px;">
                                        {% if access.member.photo is null %}
                                            <img src="https://ui-avatars.com/api/?name={{ access.member.name }}&background=random" alt="Profil" class="w-100 h-100">
                                        {% else %}
                                            <img src="{{ asset('assets/uploads/user/' ~ access.member.photo) }}" alt="Profil" class="w-100 h-100 object-fit-cover">
                                        {% endif %}
                                    </div>
                                    <p class="fw-bold text-white m-0">{{ access.member.firstname }} {{ access.member.name }}</p>
                                </div>
                            {% else %}
                                <p class="text-white"> <strong>Vous</strong> </p>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                    
                    <div class="d-flex align-items-center gap-1 text-white small">
                        {{ ux_icon('tdesign:member-filled') }} {{ session.sessionAccesses|length }} membres
                    </div>
                </div>
                <div class="card-footer border-top d-flex gap-2 py-2 px-3">
                    <a href="{{ path('app_session_home', {id: session.id}) }} " class="btn btn-sm btn-primary flex-fill">Rejoindre</a>
                </div>
            </div>
        </div>
    {% else %}
        <h5 class="text-center text-white-50"> Aucune Session. Créez votre session !</h5>
    {% endfor %}
</div>

<div class="d-flex align-items-center justify-content-between w-100 py-2 border-bottom border-white pb-2">
    <h3 class="fw-medium mb-0">
        Vos Signalement
    </h3>
</div>

<div class="row g-3 py-3">
    {% for report in arrReport %}
        <div class="col-12 col-md-6">
            <div class="card border h-100">
                <div class="card-body d-flex flex-column gap-2">
                    <div class="d-flex align-items-start justify-content-between">
                        <span class="badge bg-warning text-dark">Signalement</span>
                        <small class="text-white">{{ report.sendAt.date|format_datetime('long', 'none', locale='fr') }}</small>
                    </div>

                    <div class="d-flex flex-column gap-1">
                        <h6 class="text-white text-uppercase fw-semibold" >Sujet:</h6>
                        <p class="mb-0 text-white small">{{ report.subject }}</p>
                    </div>

                    <div class="d-flex flex-column gap-1">
                        <h6 class="text-white text-uppercase fw-semibold">Message:</h6>
                        <p class="mb-0 text-white small">{{ report.content }}</p>
                    </div>

                    <div class="d-flex flex-column gap-1">
                        <h6 class="text-white text-uppercase fw-semibold">Réponse:</h6>
                        {% if report.response %}
                            <p class="mb-0 text-white small">{{ report.response }}</p>
                        {% else %}
                            <span class="badge bg-secondary">En attente</span>
                        {% endif %}
                    </div>
                </div>

                <div class="card-footer border-top d-flex py-2 px-3 gap-2">
                    {% if report.response %}
                        <a href="" class="btn btn-sm btn-warning flex-fill">Supprimer</a> 
                    {% else %}
                        <a href="" class="btn btn-sm btn-danger flex-fill">Annuler</a> 
                        <a href="" class="btn btn-sm btn-primary flex-fill">Modifier</a> 
                    {% endif %}
                </div>
            </div>
        </div>
    {% else %}
        <h5 class="text-center text-white-50"> Aucune Signalement.</h5>
    {% endfor %}
</div>

{% endblock %}
