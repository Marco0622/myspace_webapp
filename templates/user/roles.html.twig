{% extends 'base.html.twig' %}

{% block title %}Informations utilisateur{% endblock %}

{% block body %}

<h1>Gestion des Roles</h1>



<div class="card mt-5">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="rounded-circle overflow-hidden border border-2 border-white flex-shrink-0" style="width: 64px; height: 64px;">
            {% if user.photo is null %}
                <img src="https://ui-avatars.com/api/?name={{ user.name }}&background=random" alt="Profil" class="w-100 h-100">
            {% else %}
                <img src="{{ asset('assets/uploads/user/' ~ user.photo) }}" alt="Profil" class="w-100 h-100 object-fit-cover">
            {% endif %}
        </div>
        <div>
            <h1 class="h5 mb-1 fw-500 text-white">{{ user.firstname }} {{ user.name }}</h1>
        </div>
    </div>
    <p class="text-white">Modifier les rôles de {{ user.firstname }}</p>

    
    {% if formError %}
        <div class="alert alert-danger" role="alert">{{ formError }}</div>
    {% endif %}

   
    <form method="POST" action="{{ path('app_user_roles', { id: user.id }) }}">

        <div class="form-check">
            <input type="checkbox" class="form-check-input" 
                
                {% if 'ROLE_ADMIN' in user.roles %} checked {% endif %}

                name="user-role-admin" id="user-role-admin" />

            <label class="form-check-label text-white" for="user-role-prof">Administrateur</label>
        </div>
        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('user_role') }}">

        <button type="submit" class=" mt-2 btn btn-light">Enregister</button>

    </form>
    </div>
</div>

{% endblock %}