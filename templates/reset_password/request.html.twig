{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}

    <div class="d-flex align-items-center justify-content-center mt-5" style="min-height: 70vh;">
        <div class="col-md-6">

            {% for flash_error in app.flashes('reset_password_error') %}
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>{{ flash_error }}
                </div>
            {% endfor %}

            <div class="card shadow-sm">
                <div class="card-body p-4">

                    <i class="bi bi-key fs-1 text-primary mb-3 d-block text-center"></i>

                    <h4 class="card-title text-center mb-1">Mot de passe oublié ?</h4>
                    <p class="text-muted text-center small mb-4 text-white">
                        Saisissez votre adresse email, nous vous enverrons un lien pour réinitialiser votre mot de passe.
                    </p>

                    {{ form_start(requestForm) }}
                        {{ form_row(requestForm.email) }}
                        <div class="d-grid mt-3">
                            <button class="btn btn-light">
                                <i class="bi bi-send me-2"></i>Envoyer le lien de réinitialisation
                            </button>
                        </div>
                    {{ form_end(requestForm) }}

                </div>
            </div>

        </div>
    </div>

{% endblock %}