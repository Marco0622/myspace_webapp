{% extends 'base.html.twig' %}

{% block title %}Email de réinitialisation envoyé{% endblock %}

{% block body %}
<div class="mt-5 d-flex align-items-center justify-content-center" style="min-height: 65vh;">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body text-center p-4">

                    <i class="bi bi-envelope-check fs-1 text-success mb-3 d-block"></i>

                    <h2 class="card-title mb-3 text-white">Email envoyé!</h2>

                    <p class="text-muted text-white">
                        Si un compte correspond à votre adresse email, un message vient d'être envoyé avec un lien pour réinitialiser votre mot de passe.
                        Ce lien expirera dans <strong>{{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}</strong>.
                    </p>

                    <hr>

                    <p class="text-muted small text-white">
                        Vous n'avez rien reçu ? Pensez à vérifier vos spams ou
                        <a href="{{ path('app_forgot_password_request') }}">réessayez avec une autre adresse</a>.
                    </p>

                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}