{% extends 'base.html.twig' %}

{% block title %}Session -
	{{ session.name }}
{% endblock %}

{% block body %}
	<div class="py-3">
		<twig:NavSession session="{{ session }}" allPage="{{ session.sessionPages }}"/>
	</div>
	<h1 class="h2">SESSION :
		{{ session.name }}</h1>
	<div class="row g-4 mt-2">
		<div class="accordion" id="accordionExample">
			<div class="accordion-item">
				<h2 class="accordion-header border-bottom border-white" id="headingOne">
					<button class="accordion-button collapsed text-white" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
						Liste des utilisateurs
						<twig:ux:icon name="lucide:users" class="ms-2" style="width:32px;height:32px;"/>
					</button>
				</h2>
				<div id="collapseOne" class="accordion-collapse collapse" aria-labelledby="headingOne" data-bs-parent="#accordionExample">
					<div class="accordion-body">
						{% for access in session.sessionAccesses %}
							<div class="d-flex align-items-center gap-2 py-2">
								<div class="rounded-circle overflow-hidden border border-2 border-white flex-shrink-0" style="width: 40px; height: 40px;">
									{% if access.member.photo is null %}
										<img src="https://ui-avatars.com/api/?name={{ access.member.firstname ~" "~ access.member.name }}&background=random" alt="Profil" class="w-100 h-100">
									{% else %}
										<img src="{{ asset('assets/uploads/pictures/' ~ access.member.photo) }}" alt="Profil" class="w-100 h-100 object-fit-cover">
									{% endif %}
								</div>
								{% if access.member != app.user %}
									<span class="fw-semibold text-white">{{ access.member.pseudo ?? (access.member.firstname ~" "~ access.member.name) }}</span>
								{% else %}
									<span class="fw-semibold text-white">Vous</span>
								{% endif %}

								{% if 'ROLE_EDITOR' in access.role %}
									<span class="badge rounded-pill text-bg-primary text-capitalize">éditeur</span>
								{% elseif 'ROLE_VISITOR' in access.role %}
									<span class="badge rounded-pill text-bg-success text-capitalize">Visiteur</span>
								{% else %}
									<span class="badge rounded-pill text-bg-danger text-capitalize">Propriétaire</span>
								{% endif %}

								{% if is_granted('IS_OWNER_SESSION', session) and access.member != app.user %}
									<button class="btn btn-sm btn-outline-warning ms-auto" data-bs-toggle="modal" data-bs-target="#manageModal-{{ access.id }}">
										Gérer
										<twig:ux:icon name="mingcute:edit-line" style="width:20px;height:20px;"/>
									</button>
								{% endif %}
							</div>

							<div class="modal fade" id="manageModal-{{ access.id }}" tabindex="-1" aria-labelledby="manageModalLabel-{{ access.id }}" aria-hidden="true">
								<div class="modal-dialog modal-dialog-centered">
									<div class="modal-content">
										<div class="modal-header">
											<h5 class="modal-title" id="manageModalLabel-{{ access.id }}">
												Gérer
												{{access.member.pseudo ?? (access.member.firstname ~" "~ access.member.name) }}
											</h5>
											<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
										</div>
										<div class="modal-body d-flex flex-column gap-3">
											<button class="btn btn-outline-primary w-100" data-bs-toggle="modal" data-bs-target="#roleModal-{{ access.id }}">
												<i class="bi bi-shield-fill me-1"></i>
												Modifier le rôle
											</button>
											<button class="btn btn-outline-danger w-100" data-bs-toggle="modal" data-bs-target="#excludeModal-{{ access.id }}">
												<i class="bi bi-person-x-fill me-1"></i>
												Exclure ce membre
											</button>

										</div>
									</div>
								</div>
							</div>
							<div class="modal fade" id="roleModal-{{ access.id }}" tabindex="-1" aria-labelledby="roleModalLabel-{{ access.id }}" aria-hidden="true">
								<div class="modal-dialog modal-dialog-centered">
									<div class="modal-content">
										<div class="modal-header">
											<h5 class="modal-title" id="roleModalLabel-{{ access.id }}">
												Modifier le rôle de
												{{access.member.pseudo ?? (access.member.firstname ~" "~ access.member.name) }}
											</h5>
											<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
										</div>
										<form action="{{ path('app_access_role', { id: session.id }) }}" method="post">
											<div class="modal-body">
												<label class="form-label fw-semibold">Rôle</label>
												<select name="role" class="form-select">
													<option value="editor" {% if 'ROLE_EDITOR' in access.role %} selected {% endif %}>Éditeur</option>
													<option value="visitor" {% if 'ROLE_EDITOR' not in access.role %} selected {% endif %}>Visiteur</option>
												</select>
											</div>
											<input type="hidden" name="_token" value="{{ csrf_token('role_access') }}">
											<input type="hidden" name="userToUpdate" value="{{ access.member.id }}">
											<div class="modal-footer">
												<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
												<button type="submit" class="btn btn-primary">Enregistrer</button>
											</div>
										</form>
									</div>
								</div>
							</div>
							<div class="modal fade" id="excludeModal-{{ access.id }}" tabindex="-1" aria-labelledby="excludeModalLabel-{{ access.id }}" aria-hidden="true">
								<div class="modal-dialog modal-dialog-centered">
									<div class="modal-content">
										<div class="modal-header">
											<h5 class="modal-title text-danger" id="excludeModalLabel-{{ access.id }}">
												Exclure
												{{access.member.pseudo ?? (access.member.firstname ~" "~ access.member.name) }}
											</h5>
											<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
										</div>
										<form action="{{ path('app_access_remove', { id: session.id }) }}" method="post">
											<div class="modal-body">
												<p class="mb-0">Êtes-vous sûr de vouloir exclure
													<strong>{{access.member.pseudo ?? (access.member.firstname ~" "~ access.member.name) }}</strong>
													? Cette action lui retirera l'accès à la session.
												</p>
												<input type="hidden" name="_token" value="{{ csrf_token('remove_access') }}">
												<input type="hidden" name="userToRemove" value="{{ access.member.id }}">
											</div>
											<div class="modal-footer">
												<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
												<button type="submit" class="btn btn-danger">Confirmer l'exclusion</button>
											</div>
										</form>
									</div>
								</div>
							</div>
						{% else %}
							<div class="text-center py-5 text-muted border-secondary">
								<p class="text-white">Aucun utilisateur.</p>
							</div>
						{% endfor %}
					</div>
				</div>
			</div>
		</div>

		<div class="col-lg-8">
			{% if is_granted('IS_OWNER_SESSION', session) %}
				<div class="card card-section mb-4 text-white">
					<div class="card-header border-white">
						Inviter un participant
						<twig:ux:icon name="mynaui:send" style="height:32px;width:32px;"/>
					</div>
					<form class="card-body" action="{{ path('app_invitation_create', { id: session.id }) }}" method="POST">
						<p class="text-muted small mb-3 text-white">
							Entrez le code d'invitation de la personne à inviter dans cette session.
						</p>
						<div class="input-group invite-input-group">
							<input type="hidden" name="_token" value="{{ csrf_token('create_invitation') }}">
							<input type="text" name="code" class="form-control rounded-start" placeholder="Code d'invitation...">
							<button type="submit" class="btn btn-outline-light">
								Envoyer
							</button>
						</div>
					</form>
				</div>
			{% endif %}
			<div class="card card-section text-white">
				<div class="card-header border-white d-flex justify-content-between align-items-center">
					<span class="d-flex align-items-center gap-2">
						Invitations en attente
						<twig:ux:icon name="mingcute:time-line" style="height:32px;width:32px;"/>
					</span>
					<span class="badge bg-light text-dark rounded-circle">{{ session.sessionInvitations|length }}</span>
				</div>
				<div class="card-body p-0 px-3">
					<ul class="invite-list py-2 px-0">
						{% for invitation in session.sessionInvitations %}
							<li class="py-2  list-unstyled">
								<div class="d-flex align-items-center gap-2">
									<div class="rounded-circle overflow-hidden border border-2 border-white flex-shrink-0" style="width: 40px; height: 40px;">
										{% if invitation.receiver.photo is null %}
											<img src="https://ui-avatars.com/api/?name={{ invitation.receiver.firstname ~" "~ invitation.receiver.name }}&background=random" alt="Profil" class="w-100 h-100">
										{% else %}
											<img src="{{ asset('assets/uploads/pictures/' ~ invitation.receiver.photo) }}" alt="Profil" class="w-100 h-100 object-fit-cover">
										{% endif %}
									</div>
									<span class="fw-semibold text-white">{{ invitation.receiver.pseudo ?? (invitation.receiver.firstname ~" "~ invitation.receiver.name) }}</span>
									{% if invitation.responce is null %}
										<span class="badge rounded-pill text-bg-warning" style="font-size:11px;">En attente</span>
									{% elseif invitation.responce %}
										<span class="badge rounded-pill text-bg-success" style="font-size:11px;">Accepter</span>
									{% else %}
										<span class="badge rounded-pill text-bg-danger" style="font-size:11px;">Refuser</span>
									{% endif %}
									{% if app.user == owner %}
										{% if invitation.responce is null %}
											<button type="button" class="btn btn-outline-danger btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#modalAnnuler{{ invitation.receiver.id }}">
												Annuler
											</button>
										{% else %}
											<button type="button" class="btn btn-outline-warning btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#modalEffacer{{ invitation.receiver.id }}">
												Effacer
											</button>
										{% endif %}
									{% endif %}
									<div class="modal fade" id="modalAnnuler{{ invitation.receiver.id }}" tabindex="-1" aria-hidden="true">
										<div class="modal-dialog modal-dialog-centered">
											<div class="modal-content text-dark">
												<div class="modal-header">
													<h5 class="modal-title">Annuler l'invitation</h5>
													<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
												</div>
												<div class="modal-body">
													Voulez-vous vraiment annuler l'invitation pour
													<strong>{{ invitation.receiver.pseudo ?? (invitation.receiver.firstname ~" "~ invitation.receiver.name) }}</strong>
													?
												</div>
												<div class="modal-footer">
													<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Non</button>
													<form action="{{ path('app_invitation_delete', { id: invitation.id })}}" method="post" class="d-inline">
														<input type="hidden" name="_token" value="{{ csrf_token('delete_invitation') }}">
														<input type="hidden" name="sessionId" value="{{ session.id }}">
														<button type="submit" class="btn btn-danger d-flex align-items-center gap-1">
															Annuler
														</button>
													</form>
												</div>
											</div>
										</div>
									</div>
									<div class="modal fade" id="modalEffacer{{ invitation.receiver.id }}" tabindex="-1" aria-hidden="true">
										<div class="modal-dialog modal-dialog-centered">
											<div class="modal-content text-dark">
												<div class="modal-header">
													<h5 class="modal-title">Supprimer la notification</h5>
													<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
												</div>
												<div class="modal-body">
													Retirer cette ligne de votre historique ?
												</div>
												<div class="modal-footer">
													<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
													<form action="{{ path('app_invitation_delete', { id: invitation.id })}}" method="post" class="d-inline">
														<input type="hidden" name="_token" value="{{ csrf_token('delete_invitation') }}">
														<input type="hidden" name="sessionId" value="{{ session.id }}">
														<button type="submit" class="btn btn-warning d-flex align-items-center gap-1">
															Effacer
														</button>
													</form>
												</div>
											</div>
										</div>
									</div>
								</div>

							</li>

						{% endfor %}
					</ul>
				</div>
			</div>
		</div>
		<div class="col-lg-4 ">
			<div class="card card-section mb-4 text-white">
				<div class="card-header border-white">
					Informations
					<twig:ux:icon name="material-symbols:info-outline" style="width:32px;height:32px;"/>
				</div>
				<div class="card-body">
					<dl class="row mb-0 small">
						<dt class="col-5 text-white">Propriétaire</dt>
						<dd class="col-7 fw-semibold mb-2 text-white">{{ owner.pseudo (owner.name ~" "~ owner.firstname)}}</dd>
						<dt class="col-5 text-white">Créer le</dt>
						<dd class="col-7 mb-0 text-white">{{ session.createdAt|format_datetime( 'long', 'none', locale='fr') }}</dd>
					</dl>
				</div>
			</div>
			<div class="card card-section text-white  mb-4">
				<div class="card-header border-white">
					Stockage de la session
					<twig:ux:icon name="akar-icons:data" style="width:30px;height:30px;"/>
				</div>
				<div class="card-body">

					<div class="d-flex justify-content-between align-items-end mb-2">
						<div>
							<div class="storage-label">Utilisé</div>
						</div>
						<div class="text-end">
							<div class="storage-label">{{ storageUse }} / {{ session.storage.size }} Go</div>
						</div>
					</div>
					

					<div class="progress storage-bar mb-3">
						<div class="progress-bar bg-warning" style="width: {{ (storageUse * 100)|round }}%"></div>
					</div>
				</div>
			</div>
			<div class="card card-section text-white">
				<div class="card-header border-white">
					Session
					<twig:ux:icon name="fluent-mdl2:group" class="text-white me-3" style="width:32px;height:32px;"/>
				</div>
				<div class="card-body">
					{% if is_granted('IS_OWNER_SESSION', session) %}
						<button type="button" class="btn btn-danger btn-sm w-100 mb-2" data-bs-toggle="modal" data-bs-target="#deleteSession">
							Supprimer la Session
						</button>
						<button type="button" class="btn btn-warning btn-sm w-100" data-bs-toggle="modal" data-bs-target="#renameSession">
							Renommer la Session
						</button>

						<div class="modal fade" id="deleteSession" tabindex="-1" aria-labelledby="deleteSessionLabel" aria-hidden="true">
							<div class="modal-dialog modal-dialog-centered">
								<div class="modal-content">
									<div class="modal-header">
										<h5 class="modal-title" id="deleteSessionLabel">Supprimer la session</h5>
										<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
									</div>
									<form action="{{ path('app_session_delete', { id: session.id })}}" method="post">
										<div class="modal-body d-flex flex-column gap-3">
											<p class="mb-0">Cette action est irréversible. La session et toutes ses données seront définitivement supprimées.</p>
											<div>
												<label class="form-label fw-semibold">
													Tapez "<span class="text-danger">Je confirme</span>" pour continuer
												</label>
												<input type="hidden" name="_token" value="{{ csrf_token('delete_session') }}">
												<input type="text" class="form-control" name="deleteConfirm" placeholder="Je confirme" autocomplete="off" required pattern="Je confirme" title="Veuillez écrire exactement : je confirme">
											</div>
										</div>
										<div class="modal-footer">
											<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
											<button type="submit" class="btn btn-danger">Supprimer définitivement</button>
										</div>
									</form>
								</div>
							</div>
						</div>
						<div class="modal fade" id="renameSession" tabindex="-1" aria-labelledby="renameSessionLabel" aria-hidden="true">
							<div class="modal-dialog modal-dialog-centered">
								<div class="modal-content">
									<div class="modal-header">
										<h5 class="modal-title" id="renameSessionLabel">Renommer la session</h5>
										<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
									</div>
									<form action="{{ path('app_session_rename', { id: session.id })}}" method="post">
										<div class="modal-body d-flex flex-column gap-3">
											<p class="mb-0">Saisissez un nouveau nom pour cette session.</p>
											<div>
												<label class="form-label fw-semibold">Nouveau nom</label>
												<input type="hidden" name="_token" value="{{ csrf_token('rename_session') }}">
												<input type="text" class="form-control" name="name" placeholder="{{ session.name }}" autocomplete="off" required minlength="2">
											</div>
										</div>
										<div class="modal-footer">
											<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
											<button type="submit" class="btn btn-warning">Renommer</button>
										</div>
									</form>
								</div>
							</div>
						</div>
					{% else %}
						<button type="button" class="btn btn-warning btn-sm w-100 mb-2" data-bs-toggle="modal" data-bs-target="#leaveSession">
							<twig:ux:icon name="fluent-mdl2:leave" style="height:20px;width:20px;"/>
							Quitter la Session
						</button>
						<div class="modal fade" id="leaveSession" tabindex="-1" aria-labelledby="leaveSessionLabel" aria-hidden="true">
							<div class="modal-dialog modal-dialog-centered">
								<div class="modal-content">
									<div class="modal-header">
										<h5 class="modal-title" id="leaveSessionLabel">Quitter la session</h5>
										<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
									</div>
									<div class="modal-body">
										<p class="mb-0">Êtes-vous sûr de vouloir quitter cette session ? Vous perdrez votre accès.</p>
									</div>
									<div class="modal-footer">
										<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
										<form action="{{ path('app_access_leave', { id: session.id })}}" method="post" class="d-inline">
											<input type="hidden" name="inv_token" value="{{ csrf_token('leave_session') }}">
											<button type="submit" class="btn btn-warning d-flex align-items-center gap-1">
												Quitter
											</button>
										</form>
									</div>
								</div>
							</div>
						</div>
					{% endif %}
				</div>
			</div>
		</div>
	</div>

{% endblock %}
