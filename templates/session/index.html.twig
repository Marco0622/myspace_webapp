{% extends 'base.html.twig' %}

{% block title %}Session - {{ session.name }}
{% endblock %}

{% block body %}
	{{ dump(session) }}
    <h1 class="h2">{{ session.name }}</h1>
	<div class="row g-4 mt-3">
		<div class="col-lg-8">
			<div class="card card-section mb-4 text-white">
				<div class="card-header border-white">
					Inviter un participant
					<twig:ux:icon name="mynaui:send" style="height:32px;width:32px;"/>
				</div>
				<form class="card-body" action="{{ path('app_invitation_create', { id: session.id }) }}" method="POST">
					<p class="text-muted small mb-3 text-white">
						Entrez le code d'invitation de la personne à inviter dans cette session.
					</p>
					<div class="input-group invite-input-group">
						<input type="hidden" name="_token" value="{{ csrf_token('create_invitation') }}">
						<input type="text" name="code" class="form-control rounded-start" placeholder="Code d'invitation...">
						<button type="submit" class="btn btn-outline-light">
							Envoyer
						</button>
					</div>
				</form>
			</div>
			<div class="card card-section text-white">
				<div class="card-header border-white d-flex justify-content-between align-items-center">
					<span class="d-flex align-items-center gap-2">

						Invitations en attente
					</span>
					<span class="badge bg-light text-dark rounded-circle">{{ session.sessionInvitations|length }}</span>
				</div>
				<div class="card-body p-0 px-3">
					<ul class="invite-list py-2 px-0">
						{% for user in session.sessionInvitations %}
							<li class="py-2  list-unstyled">
								<div class="d-flex align-items-center gap-2">
									<div class="rounded-circle overflow-hidden border border-2 border-white flex-shrink-0" style="width: 40px; height: 40px;">
										{% if user.receiverId.photo is null %}
											<img src="https://ui-avatars.com/api/?name={{ user.receiverId.firstname ~" "~ user.receiverId.name }}&background=random" alt="Profil" class="w-100 h-100">
										{% else %}
											<img src="{{ asset('assets/uploads/user/' ~ user.receiverId.photo) }}" alt="Profil" class="w-100 h-100 object-fit-cover">
										{% endif %}
									</div>
									<span class="fw-semibold text-white">{{ user.receiverId.firstname ~" "~ user.receiverId.name }}</span>
									{% if user.responce is null %}
										<span class="badge rounded-pill text-bg-warning" style="font-size:11px;">En attente</span>
									{% elseif user.responce %}
										<span class="badge rounded-pill text-bg-success" style="font-size:11px;">Accepter</span>
									{% else %}
										<span class="badge rounded-pill text-bg-danger" style="font-size:11px;">Refuser</span>
									{% endif %}

									{% if user.responce is null %}
										<a href="#" class="btn btn-outline-danger btn-sm ms-auto"> Annuler </a>
									{% else %}
										<a href="#" class="btn btn-outline-warning btn-sm ms-auto"> Effacer </a>
									{% endif %}
								</div>
								
							</li>
							
						{% endfor %}
					</ul>
				</div>
			</div>
		</div>
		<div class="col-lg-4 ">
			<div class="card card-section mb-4 text-white">
				<div class="card-header border-white">
					<i class="ph ph-info text-info" style="font-size:18px"></i>
					Informations
				</div>
				<div class="card-body">
					<dl class="row mb-0 small">
						<dt class="col-5 text-white">Propriétaire</dt>
						<dd class="col-7 fw-semibold mb-2 text-white">Jean Martin</dd>
						<dt class="col-5 text-white">Expiration</dt>
						<dd class="col-7 mb-0 text-white">{{ session.createdAt|format_datetime( 'long', 'none', locale='fr') }}</dd>
					</dl>
				</div>
			</div>
			<div class="card card-section text-white  mb-4">
				<div class="card-header border-white">
					Stockage de la session
				</div>
				<div class="card-body">

					<div class="d-flex justify-content-between align-items-end mb-2">
						<div>
							<div class="storage-pct">62%</div>
							<div class="storage-label">utilisé</div>
						</div>
						<div class="text-end">
							<div class="fw-semibold small">635 Mo</div>
							<div class="storage-label">/ 1.0 Go</div>
						</div>
					</div>

					<div class="progress storage-bar mb-3" role="progressbar" aria-valuenow="62" aria-valuemin="0" aria-valuemax="100">
						<div class="progress-bar bg-warning" style="width: 62%"></div>
					</div>
				</div>
			</div>
			<div class="card card-section text-white">
				<div class="card-header border-white">
					Session
				</div>
				<div class="card-body">
					<button type="button" class="btn btn-warning w-100 mb-2" data-bs-toggle="modal" data-bs-target="#leaveSession">
						<twig:ux:icon name="fluent-mdl2:leave" style="height:20px;width:20px;"/>
						Quitter la Session
					</button>
					<div class="modal fade" id="leaveSession" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
						<div class="modal-dialog">
							<div class="modal-content">
								<div class="modal-header">
									<h5 class="modal-title" id="exampleModalLabel">Modal title</h5>
									<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
								</div>
								<div class="modal-body">
									...
								</div>
								<div class="modal-footer">
									<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
									<button type="button" class="btn btn-primary">Save changes</button>
								</div>
							</div>
						</div>
					</div>
					<button type="button" class="btn btn-danger w-100" data-bs-toggle="modal" data-bs-target="#deleteSession">
						
						Supprimer la Session
					</button>
					<div class="modal fade" id="deleteSession" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
						<div class="modal-dialog">
							<div class="modal-content">
								<div class="modal-header">
									<h5 class="modal-title" id="exampleModalLabel">Modal title</h5>
									<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
								</div>
								<div class="modal-body">
									...
								</div>
								<div class="modal-footer">
									<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
									<button type="button" class="btn btn-primary">Save changes</button>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

{% endblock %}
