{% extends 'base.html.twig' %}

{% block title %}Session -
	{{ session.name }}
{% endblock %}

{% block body %}
	<div class="mb-2">
		<twig:NavSession id="{{ session.id }}" allPage="{{ session.sessionPages }}"/>
	</div>
	<h1 class="h2">Galerie d'image</h1>
	<div class="container py-3">
		<div class="gallery-toolbar shadow-sm d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 pb-3 mb-3 border-bottom border-white">
			<div class="d-flex flex-column flex-sm-row align-items-sm-center gap-2 flex-grow-1">
				<form class="input-group input-group-sm" id="search-form">
					<button type="submit" class="input-group-text bg-dark border-secondary text-white">
						{{ ux_icon('lucide:search') }}
					</button>
					<input value="{{ query }}" type="text" name="query" class="form-control bg-dark border-secondary text-white placeholder-white" placeholder="Rechercher une image..." aria-label="Recherche">
					{% if query %}
						<a href="{{ path('app_session_gallery', { id: session.id }) }}" class="input-group-text bg-dark border-secondary text-white text-decoration-none">
							{{ ux_icon('lucide:x') }}
						</a>
					{% endif %}
				</form>
			</div>
			{% if is_granted('IS_EDITOR_SESSION', session) %}
				<div class="flex-shrink-0">
					<button class="btn btn-light btn-sm d-flex align-items-center justify-content-center gap-2" data-bs-toggle="modal" data-bs-target="#addImageModal">
						<twig:ux:icon name="icon-park-outline:add-picture" style="height:20px;width:20px;"/>
						<span>Ajouter une image</span>
					</button>
				</div>
			{% endif %}
		</div>
		<div class="masonry-grid justify-content-center">
			{% for picture in arrPicture %}
				<div class="gallery-item shadow-sm">
					<img src="{{ asset('assets/uploads/pictures/'~ picture.path)}}" alt="Portrait">
					<div class="gallery-overlay">
						<div class="text-wrap text-white fw-bold">{{ picture.name }}</div>
						{% if is_granted('IS_EDITOR_SESSION', session) %}
							<div>
								<a href="{{ path('app_picture_download_file', { id: picture.id }) }}" class="btn btn-light btn-sm shadow">
									<twig:ux:icon name="material-symbols:download" style="height:20px;width:20px; "/>
								</a>
								<button class="btn btn-danger btn-sm shadow" data-bs-toggle="modal" data-bs-target="#deleteImg{{ picture.id }}">
									<twig:ux:icon name="iconamoon:trash-thin" style="height:20px;width:20px;"/>
								</button>
								<button class="btn btn-light btn-sm shadow text-dark" data-bs-toggle="modal" data-bs-target="#editImg{{ picture.id }}" title="Renommer">
									<twig:ux:icon name="material-symbols:edit-outline" style="height:20px;width:20px;"/>
								</button>
							</div>
						{% endif %}
					</div>
				</div>
				<div class="modal fade" id="deleteImg{{ picture.id }}" tabindex="-1" aria-labelledby="deleteImg" aria-hidden="true">
					<div class="modal-dialog modal-dialog-centered">
						<div class="modal-content border-0 shadow">
							<div class="modal-header">
								<h5 class="modal-title fw-bold" id="modalTitle">Supprimer la Photo</h5>
								<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
							</div>
							<div class="modal-body text-center">
								<div class="text-center w-50 mx-auto">
									<img src="{{ asset('assets/uploads/pictures/'~ picture.path)}}" class="img-fluid rounded">
								</div>
								<div class="mt-3 small">Cette photo sera supprimée définitivement !</div>
							</div>
							<div class="modal-footer">
								<button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuler</button>
								<form action="{{ path('app_picture_delete', { id: picture.id })}}" method="post" class="d-inline">
									<input type="hidden" name="_token" value="{{ csrf_token('delete_picture') }}">
									<button type="submit" class="btn btn-danger d-flex align-items-center gap-1">
										Supprimer
									</button>
								</form>
							</div>
						</div>
					</div>
				</div>
				<div class="modal fade" id="editImg{{ picture.id }}" tabindex="-1" aria-hidden="true">
					<div class="modal-dialog modal-dialog-centered">
						<div class="modal-content border-0 shadow">
							<form action="{{ path('app_picture_rename', { id: picture.id }) }}" method="post">
								<div class="modal-header">
									<h5 class="modal-title fw-bold">Modifier le nom</h5>
									<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
								</div>
								<div class="modal-body">
									<div class="mb-3">
										<label for="name{{ picture.id }}" class="form-label small fw-bold">Nom de l'image</label>
										<input type="text" name="name" id="name{{ picture.id }}" class="form-control" value="{{ picture.name }}" required>
									</div>
									<input type="hidden" name="_token" value="{{ csrf_token('rename_picture') }}">
								</div>
								<div class="modal-footer">
									<button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuler</button>
									<button type="submit" class="btn btn-success text-white">Enregistrer</button>
								</div>
							</form>
						</div>
					</div>
				</div>
			{% else %}
				<div class="py-5 text-center">
					<p class="h5 text-white-50 ">Aucun élément trouver !</p>
				</div>
			{% endfor %}
		</div>
		<div class="modal fade" id="addImageModal" tabindex="-1" aria-labelledby="modalTitle" aria-hidden="true">
			<div class="modal-dialog modal-dialog-centered">
				<form action="{{ path('app_picture_download', { id: session.id }) }}" class="modal-content border-0 shadow" method="post" enctype="multipart/form-data">
					<div class="modal-header">
						<h5 class="modal-title fw-bold" id="modalTitle">Nouvelle Image</h5>
						<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
					</div>
					<div class="modal-body">
						<div>
							<div class="mb-3">
								<label class="form-label small fw-bold">Sélectionner le fichier</label>
								<input type="file" name="photo" class="form-control">
							</div>
							<div class="form-check form-switch">
								<input class="form-check-input" type="checkbox" value="optimization" id="checkOpti" name="checkOpti" switch>
								<label class="form-check-label" for="checkNativeSwitch">
									Optionnel : Optimiser l'image ?
								</label>
							</div>
							<input type="hidden" value="{{ csrf_token('download_picture') }}" name="_token">
						</div>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuler</button>
						<button type="submit" class="btn btn-primary">Enregistrer</button>
					</div>
				</form>
			</div>
		</div>
	{% endblock %}
