{% extends 'base.html.twig' %}

{% block title %}Session -
	{{ session.name }}
{% endblock %}

{% block javascripts %}
	<script src="{{ asset('/assets/js/tinymce/tinymce.min.js') }}"></script>
	{{ importmap(['app', 'editor']) }}
{% endblock %}

{% block body %}
	<div class="py-3">
		<twig:NavSession session="{{ session }}" allPage="{{ session.sessionPages }}"/>
	</div>
	<div class="d-flex align-items-center">
		<h1 class="h2 d-block">{{ page.name }}</h1>
		{% if is_granted('IS_EDITOR_SESSION', session) %}
			<button type="button" class="btn btn-outline-danger ms-auto btn-sm py-1" data-bs-toggle="modal" data-bs-target="#deletePageModal">
				<twig:ux:icon name="formkit:trash"/>
				Supprimer la page
			</button>
		{% endif %}
	</div>
	<div class="modal fade" id="deletePageModal" tabindex="-1" aria-labelledby="deletePageModalLabel" aria-hidden="true">
		<div class="modal-dialog">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title" id="deletePageModalLabel">Confirmer la suppression</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					Êtes-vous sûr de vouloir supprimer la page
					<strong>{{ page.name }}</strong>
					? Cette action est irréversible.
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
					<form action="{{ path('app_page_delete', { id: page.id }) }}" method="POST" style="display:inline;" data-turbo="false">
						<input type="hidden" name="_token" value="{{ csrf_token('delete_page') }}">
						<button type="submit" class="btn btn-danger">Supprimer définitivement</button>
					</form>
				</div>
			</div>
		</div>
	</div>
	<div class="save-indicator" id="save-indicator"></div>
	<div class="main-container">
		<textarea id="my-editor" data-id="{{ page.id }}" data-token="{{ csrf_token('save_page') }}" {% if is_granted('IS_EDITOR_SESSION', session) %} data-bool="false" {% else %} data-bool="true" {% endif %}>{{ page.content }}</textarea>
	</div>
{% endblock %}
