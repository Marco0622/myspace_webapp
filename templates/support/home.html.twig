{% extends 'base.html.twig' %}

{% block title %}Accueil -
	{{ parent() }}
{% endblock %}

{% block body %}
	<div class="container py-5">

		<div class="row align-items-center mb-5 pb-4" style="border-bottom:1px solid #2a2a2a">
			<div class="col-lg-7 mb-4 mb-lg-0 ">
				<h1 class="mb-3 text-center text-md-start text-capitalize">Bienvenue<br>sur MySpace</h1>
				<p class="hero-sub mb-4">
					Gérez vos sessions, invitez vos équipes et collaborez<br>
					en temps réel depuis un seul espace centralisé.
				</p>
				<div class="d-flex flex-wrap gap-2 ">
					<a href="{{ path('app_register') }}" class="btn btn-light px-4">
						{{ ux_icon('bi:plus-lg', {class: 'me-1'}) }}
						Créer un compte
					</a>
					<a href="{{ path('app_login') }}" class="btn btn-outline-light px-4">Se connecter</a>
				</div>
			</div>
			<div class="col-lg-5">
				<div class="row g-4">
					<div class="col-6">
						<div class="stat-block">
							<div class="stat-num">10 Go</div>
							<div class="stat-label">Stockage gratuit</div>
						</div>
					</div>
					<div class="col-6">
						<div class="stat-block">
							<div class="stat-num">∞</div>
							<div class="stat-label">Membres / session</div>
						</div>
					</div>
					<div class="col-6">
						<div class="stat-block">
							<div class="stat-num">100%</div>
							<div class="stat-label">Données chiffrées</div>
						</div>
					</div>
					<div class="col-6">
						<div class="stat-block">
							<div class="stat-num">24/7</div>
							<div class="stat-label">Disponible</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="mb-5">
			<div class="section-title text-uppercase">Nos fonctionnalités</div>
			<div class="row g-3">
				<div class="col-md-4">
					<div class="feature-card p-4 h-100">
						<div class="mb-2 text-white">
							{{ ux_icon('bi:grid-3x3-gap') }}
						</div>
						<div class="fw-bold text-white mb-1">Sessions</div>
						<p class="mb-0" style="font-size:.82rem;color:#888;">Créez des sessions de travail et invitez vos collaborateurs à les rejoindre instantanément.</p>
					</div>
				</div>
				<div class="col-md-4">
					<div class="feature-card p-4 h-100">
						<div class="mb-2 text-white">
							{{ ux_icon('bi:envelope-paper') }}
						</div>
						<div class="fw-bold text-white mb-1">Invitations</div>
						<p class="mb-0" style="font-size:.82rem;color:#888;">Envoyez et recevez des invitations. Rejoignez l'espace d'un autre utilisateur en un clic.</p>
					</div>
				</div>
				<div class="col-md-4 ">
					<div class="feature-card p-4 h-100">
						<div class="mb-2 text-white">

							{{ ux_icon('bi:shield-lock') }}
						</div>
						<div class="fw-bold text-white mb-1">Sécurité</div>
						<p class="mb-0" style="font-size:.82rem;color:#888;">Contrôlez les accès, les permissions et gardez vos données en sécurité à tout moment.</p>
					</div>
				</div>
			</div>
		</div>

		<div class="mb-5">
			<div class="d-flex justify-content-between align-items-center mb-3" style="border-bottom:1px solid #333;padding-bottom:.5rem;">
				<span style="font-size:1.15rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em">Aperçu — vos sessions</span>
				<button class="btn btn-outline-light btn-sm">
					{{ ux_icon('bi:plus', {class: 'me-1'}) }}
					Créer une session
				</button>
			</div>
			<div class="row g-3">
				<div class="col-md-4">
					<div class="feature-card p-3">
						<div class="d-flex justify-content-between align-items-center mb-2">
							<span class="badge-session">Session</span>
							<small style="color:#555;font-size:.75rem">23 avril 2026</small>
						</div>
						<div class="fw-bold text-white mb-1">NOM_SESSION</div>
						<div style="font-size:.78rem;color:#888;margin-bottom:.75rem">Propriétaire :</div>
						<div class="d-flex align-items-center gap-2 mb-3">
							<div class="avatar-placeholder">
								{{ ux_icon('bi:person') }}
							</div>
							<span style="font-size:.82rem">Vous</span>
						</div>
						<div class="d-flex align-items-center gap-1 mb-3" style="font-size:.78rem;color:#888;">
							{{ ux_icon('bi:people', {style: 'width: 14px; height: 14px'}) }}
							1 membre
						</div>
						<button class="btn btn-primary w-100 btn-sm">Rejoindre</button>
					</div>
				</div>
				<div class="col-md-4 d-flex align-items-center justify-content-center">
					<div class="text-center" style="color:#444; cursor: pointer;">
						<div style="font-size:2rem">
							{{ ux_icon('bi:plus-circle') }}
						</div>
						<div style="font-size:.8rem;margin-top:.5rem">Créer une session</div>
					</div>
				</div>
			</div>
		</div>

		<div class="feature-card p-4 text-center">
			<div style="font-size:1.15rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.5rem">Prêt à commencer ?</div>
			<p style="font-size:.85rem;color:#888;margin-bottom:1.25rem">Créez votre compte et lancez votre premier espace en moins d'une minute.</p>
			<a href="{{ path('app_register') }}" class="btn btn-light px-5">
				{{ ux_icon('bi:plus-lg', {class: 'me-1'}) }}
				Créer mon espace
			</a>
		</div>

	</div>
{% endblock %}
