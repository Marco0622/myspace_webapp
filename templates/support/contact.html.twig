{% extends 'base.html.twig' %}

{% block title %}Contact - {{ parent() }}{% endblock %}

{% block body %}
<section class="py-5">
    <div class="row justify-content-center">
        <div class="card p-3 p-lg-5">
            <h1 class="display-5 mb-4 text-white text-uppercase fw-bold">Contact</h1>
            <p class="text-white-50 mb-5">Une question ou un projet ? Envoyez-moi un message via le formulaire ci-dessous.</p>
            {% if strFormError %}
                <div class="alert alert-danger" role="alert">{{ strFormError }}</div>
            {% endif %}
            <form action="{{ path('app_support_contact') }}" method="POST">
                <div class="row g-4">
                    <div class="col-md-6">
                        <label for="fullName" class="form-label text-white small text-uppercase">Nom complet*</label>
                        <input value="{{ fullName }}" type="text" class="form-control text-dark border-secondary py-3 focus-ring focus-ring-light" id="name" name="fullName" placeholder="Jean Dupont"  required>
                    </div>

                    <div class="col-md-6">
                        <label for="email" class="form-label text-white small text-uppercase">Email*</label>
                        <input value="{{ userEmail }}" type="email" class="form-control text-dark border-secondary py-3 focus-ring focus-ring-light" id="email" name="email" placeholder="nom@exemple.com" required>
                    </div>

                    <div class="col-12">
                        <label for="subject" class="form-label text-white small text-uppercase">Objet*</label>
                        <input value="{{ subject }}" type="text" class="form-control text-dark border-secondary py-3 focus-ring focus-ring-light" id="subject" name="subject" placeholder="Sujet de votre message">
                    </div>

                    <div class="col-12">
                        <label for="message" class="form-label text-white small text-uppercase">Message*</label>
                        <textarea class="form-control text-dark border-secondary py-3 focus-ring focus-ring-light" id="message" name="message" row="4" placeholder="Votre message ici..." required>{{ message }}</textarea>
                    </div>
                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('contact_form') }}">
                    <div class="col-12 mt-4">
                        <button type="submit" class="btn btn-outline-light btn-lg px-5 text-uppercase fw-bold w-100">
                            Envoyer
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>
{% endblock %}
