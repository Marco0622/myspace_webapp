{% extends 'base.html.twig' %}

{% block title %}Politique de Confidentialité - {{ parent() }}{% endblock %}

{% block body %}
<section class="py-5">
    <h1 class="display-5 mb-5 text-uppercase fw-bold">Politique de Confidentialité</h1>
    
    <div class="mb-5">
        <h2 class="h4 mb-3">1. Collecte des données</h2>
        <p class="text-white-50">
            Nous collectons uniquement les données nécessaires à la fourniture de nos services : 
            nom, adresse email et données de navigation.
        </p>
    </div>

    <div class="mb-5">
        <h2 class="h4 mb-3">2. Vos Droits (RGPD)</h2>
        <p class="text-white-50 mb-4">
            Conformément à la réglementation européenne, vous disposez des droits suivants :
        </p>
        <div class="d-flex flex-wrap gap-2">
            <span class="border border-secondary px-3 py-2 rounded">Accès</span>
            <span class="border border-secondary px-3 py-2 rounded">Rectification</span>
            <span class="border border-secondary px-3 py-2 rounded">Suppression</span>
            <span class="border border-secondary px-3 py-2 rounded">Opposition</span>
        </div>
    </div>

    <div class="mb-5">
        <h2 class="h4 mb-3">3. Contact</h2>
        <p class="text-white-50">
            Pour toute demande concernant vos données personnelles, contactez-nous à : 
            <span class="text-primary fw-bold">[Votre Email]</span>
        </p>
    </div>

    <p class="small text-white mt-5 pt-4 border-top border-secondary">
        Dernière mise à jour : 9 avril 2026
    </p>
</section>
{% endblock %}
