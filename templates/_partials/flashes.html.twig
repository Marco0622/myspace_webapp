{% for type, messages in app.flashes %}
    {% for message in messages %}

        <div class="alert alert-{{ type }} alert-dismissible fade show d-flex align-items-center gap-2" role="alert">

            {% if type == 'success' %}
                {{ ux_icon('lucide:circle-check', { class: 'flex-shrink-0' }) }}
            {% elseif type == 'error' or type == 'danger' %}
                {{ ux_icon('lucide:triangle-alert', { class: 'flex-shrink-0' }) }}
            {% elseif type == 'warning' %}
                {{ ux_icon('lucide:circle-alert', { class: 'flex-shrink-0' }) }}
            {% else %}
                {{ ux_icon('lucide:info', { class: 'flex-shrink-0' }) }}
            {% endif %}

            <span>{{ message }}</span>

            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>

    {% endfor %}
{% endfor %}